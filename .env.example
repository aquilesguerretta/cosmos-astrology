# ─── Cosmos environment ───
# Copy to .env.local and fill in. Auth + DB activate only when AUTH_SECRET and
# DATABASE_URL are both set; otherwise the app runs in demo mode.

# PostgreSQL (e.g. Neon, Supabase, Railway)
DATABASE_URL="postgresql://user:password@host:5432/cosmos?schema=public"

# NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET=
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (Google Cloud Console → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Anthropic Claude (AI interpretations, horoscopes, Ask the Stars)
ANTHROPIC_API_KEY=
# Optional model override (default: claude-sonnet-4-5)
ANTHROPIC_MODEL=

# OpenCage geocoding (city → lat/lng); static city list is used until set
OPENCAGE_API_KEY=
